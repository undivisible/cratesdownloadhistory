---
import Base from '../layouts/Base.astro';

const user = Astro.url.searchParams.get('user')?.trim();
if (user) return Astro.redirect(`/${encodeURIComponent(user)}`);
---

<Base title="crates download history">
  <h1>crates download history</h1>
  <p class="muted mb-6">
    total downloads over time for a crates.io user —&nbsp;<a href="https://github.com/undivisible/cratesdownloadhistory">github</a>
  </p>

  <form class="flex flex-wrap gap-2 items-end" id="search">
    <label class="flex flex-col gap-1">
      crates.io user
      <input id="user" name="user" type="text" placeholder="undivisible" required class="min-w-200" />
    </label>
    <button type="submit">view</button>
  </form>

  <script>
    document.getElementById('search')?.addEventListener('submit', (event) => {
      event.preventDefault();
      const input = document.getElementById('user');
      const value = input instanceof HTMLInputElement ? input.value.trim() : '';
      if (value) window.location.href = `/${encodeURIComponent(value)}`;
    });
  </script>
</Base>