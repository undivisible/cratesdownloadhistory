---
import Base from '../layouts/Base.astro';
---

<Base title="crates download history">
  <h1 class="text-base font-600 mb-4 lowercase">crates download history</h1>
  <p class="text-[var(--muted)] mb-6">total downloads over time for a crates.io user</p>

  <form class="flex flex-wrap gap-2 items-end" id="search">
    <label class="flex flex-col gap-1">
      crates.io user
      <input id="user" name="user" type="text" placeholder="undivisible" required class="min-w-200px" />
    </label>
    <button type="submit">view</button>
  </form>

  <script>
    const params = new URLSearchParams(window.location.search);
    const user = params.get('user');
    if (user) {
      window.location.replace(`/${encodeURIComponent(user)}`);
    }

    document.getElementById('search')?.addEventListener('submit', (event) => {
      event.preventDefault();
      const input = document.getElementById('user');
      const value = input instanceof HTMLInputElement ? input.value.trim() : '';
      if (value) window.location.href = `/${encodeURIComponent(value)}`;
    });
  </script>
</Base>