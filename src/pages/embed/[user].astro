---
export const prerender = false;

import { loadUserHistory } from '../../lib/history';
import { renderSvg } from '../../lib/chart';
import { loadOptions } from '../../lib/runtime';

const { user: login } = Astro.params;
if (!login) return new Response('not found', { status: 404 });

let svg = '';
try {
  const history = await loadUserHistory(login, loadOptions(Astro.locals.cfContext));
  svg = renderSvg(history.points, {
    width: 800,
    height: 300,
    title: `${history.user.login} — ${history.totalDownloads.toLocaleString()} downloads`,
  });
} catch {
  return new Response('not found', { status: 404 });
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{login}</title>
    <style>
      body {
        margin: 0;
        background: #fff;
      }
      svg {
        display: block;
        width: 100%;
        height: auto;
      }
    </style>
  </head>
  <body set:html={svg} />
</html>