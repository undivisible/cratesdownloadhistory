---
import { siteThemeCss } from '../lib/site-theme';

interface Props {
  title: string;
  theme?: string;
  minimal?: boolean;
}

const { title, theme = 'light', minimal = false } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <style is:global set:html={siteThemeCss()} />
    <style is:global>
      :root,
      [data-theme] {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        background: var(--bg);
        color: var(--fg);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--fg);
      }

      a { color: var(--fg); }

      input,
      button,
      select,
      textarea {
        font: inherit;
        border: 1px solid var(--border);
        background: var(--bg);
        color: var(--fg);
        padding: 0.5rem 0.75rem;
      }

      button,
      a.button {
        cursor: pointer;
      }

      button:hover,
      a:hover {
        background: var(--hover-bg);
        color: var(--hover-fg);
      }

      pre {
        border: 1px solid var(--border);
      }
    </style>
  </head>
  <body class="bg-[var(--bg)] text-[var(--fg)]">
    {
      !minimal && (
        <div class="max-w-900px mx-auto px-4 py-8">
          <slot />
        </div>
      )
    }
    {minimal && <slot />}
  </body>
</html>